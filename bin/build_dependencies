#!/bin/bash

set -e

pushd packages
  docker build . -t localhost/mock:latest

  arch_packages="repmgr16"
  for package in $arch_packages
  do
    echo "Building $package"
    pushd $package
      docker run --rm --privileged --cap-add SYS_ADMIN -v $(pwd):/work:z localhost/mock:latest ./build
      ls -al result/
    popd
  done

  echo "Done!"
popd

set +e
